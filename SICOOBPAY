name: Build APK

on:
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      
      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'
      
      - name: Install Capacitor
        run: |
          npm install @capacitor/core @capacitor/cli @capacitor/android
          npx cap init SicoobPay com.sicoob.pay
          npx cap add android
          npx cap copy
      
      - name: Build APK
        run: |
          cd android
          chmod +x gradlew
          ./gradlew assembleDebug
          cd ..
          cp android/app/build/outputs/apk/debug/app-debug.apk SicoobPay.apk
      
      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: SicoobPay-APK
          path: SicoobPay.apk
